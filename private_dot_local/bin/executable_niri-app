#!/usr/bin/env bash
set -euo pipefail

make_candidates() {
  local item base lower candidate stem

  for item in "$@"; do
    [[ "$item" == -* ]] && continue

    for base in "$(basename "$(dirname "$item")")" "$(basename "$item")"; do
      [[ -z "$base" || "$base" == "." || "$base" == "/" ]] && continue

      lower="$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]')"

      case "$lower" in
        zed | zeditor)
          printf '%s\n' zed
          printf '%s\n' zeditor
          ;;
      esac

      for candidate in \
        "$lower" \
        "${lower%.appimage}" \
        "${lower%.desktop}" \
        "${lower%-stable}" \
        "${lower%-browser}" \
        "${lower%-bin}"
      do
        [[ -z "$candidate" ]] && continue
        printf '%s\n' "$candidate"
        printf '%s\n' "$(normalize_name "$candidate")"

        stem="${candidate%%-linux-*}"
        if [[ "$stem" != "$candidate" && -n "$stem" ]]; then
          printf '%s\n' "$stem"
          printf '%s\n' "$(normalize_name "$stem")"
        fi
      done
    done
  done
}

normalize_name() {
  local value

  value="$(
    printf '%s' "$1" |
      tr '[:upper:]' '[:lower:]' |
      sed 's/developers/developer/g' |
      tr -cd '[:alnum:]'
  )"

  case "$value" in
    firefoxdev)
      printf '%s' firefoxdeveloperedition
      ;;
    *)
      printf '%s' "$value"
      ;;
  esac
}

find_matching_window() {
  local apps_json="$1"
  local -a apps aliases
  local best_id="" best_focused="" best_app_id="" best_rank=999999
  local windows_json win_id focused app_id rank app alias matched

  windows_json="$(cat)"

  mapfile -t apps < <(jq -r '.[]' <<<"$apps_json")

  while IFS=$'\t' read -r win_id focused app_id; do
    aliases=()
    window_aliases "$app_id" aliases

    matched=false
    rank=0
    for app in "${apps[@]}"; do
      for alias in "${aliases[@]}"; do
        if [[ "$alias" == "$app" ]]; then
          matched=true
          break 2
        fi
      done
      ((++rank))
    done

    if [[ "$matched" == true ]]; then
      if (( rank < best_rank )) || { (( rank == best_rank )) && [[ "$focused" == true && "$best_focused" != true ]]; }; then
        best_id="$win_id"
        best_focused="$focused"
        best_app_id="$app_id"
        best_rank="$rank"
      fi
    fi
  done < <(jq -r '.[] | [.id, (.is_focused|tostring), (.app_id // "")] | @tsv' <<<"$windows_json")

  if [[ -n "$best_id" ]]; then
    printf '%s\t%s\t%s\n' "$best_id" "$best_focused" "$best_app_id"
  fi
}

strip_suffix() {
  local value="$1"
  value="${value%.appimage}"
  value="${value%.desktop}"
  value="${value%-stable}"
  value="${value%-browser}"
  value="${value%-bin}"
  printf '%s' "$value"
}

window_aliases() {
  local app_id="$1"
  local -n out="$2"
  local app_lower last candidate

  app_lower="${app_id,,}"
  last="${app_lower##*.}"

  for candidate in \
    "$app_lower" \
    "$last" \
    "$(strip_suffix "$app_lower")" \
    "$(strip_suffix "$last")"
  do
    [[ -z "$candidate" ]] && continue
    out+=("$candidate")
    out+=("$(normalize_name "$candidate")")
  done
}

launch_app() {
  {
    printf '\n[%s] launching:' "$(date '+%F %T')"
    printf ' %q' "${cmd[@]}"
    printf '\n'
  } >>"$log_file"

  if command -v setsid >/dev/null 2>&1; then
    setsid -f -- "${cmd[@]}" >>"$log_file" 2>&1 || {
      echo "Failed to launch: ${cmd[*]}" >&2
      echo "See log: $log_file" >&2
      exit 1
    }
  else
    nohup "${cmd[@]}" >>"$log_file" 2>&1 &
  fi
}

main() {
  local windows match apps_json close_when_focused=false

  case "${1:-}" in
  -h | --help | "")
    echo "Usage:"
    echo "  niri-app [--close] COMMAND [ARGS...]"
    echo
    echo "Examples:"
    echo "  niri-app --close zen-browser"
    echo "  niri-app --close thunderbird"
    echo "  niri-app --close kate"
    echo "  niri-app --close flatpak run org.mozilla.Thunderbird"
    exit 0
    ;;

  -c | --close)
    close_when_focused=true
    shift
    ;;
  esac

  if (("$#" == 0)); then
    echo "Missing command" >&2
    exit 1
  fi

  cmd=("$@")

  log_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
  log_file="$log_dir/niri-app.log"
  mkdir -p "$log_dir"

  apps_json="$(
    make_candidates "${cmd[@]}" |
      awk 'NF && !seen[$0]++' |
      jq -R . |
      jq -s .
  )"

  windows="$(niri msg -j windows)"
  match="$(find_matching_window "$apps_json" <<<"$windows")"

  if [[ -z "$match" ]]; then
    launch_app
    exit 0
  fi

  IFS=$'\t' read -r win_id focused matched_app_id <<<"$match"

  if [[ "$close_when_focused" == true && "$focused" == "true" ]]; then
    niri msg action close-window --id "$win_id"
  else
    niri msg action focus-window --id "$win_id"
  fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
