#!/usr/bin/env python3
"""Print Codex weekly subscription usage as a used percentage."""

import json
import selectors
import shutil
import subprocess
import sys
import time
from pathlib import Path


def find_codex() -> str | None:
    """Find Codex even when Quickshell was started with a minimal PATH."""
    candidates = [
        shutil.which("codex"),
        str(Path.home() / ".local/share/npm/bin/codex"),
        str(Path.home() / ".local/bin/codex"),
    ]
    return next((path for path in candidates if path and Path(path).is_file()), None)


def main() -> int:
    codex = find_codex()
    if codex is None:
        return 1

    try:
        process = subprocess.Popen(
            [codex, "app-server", "--listen", "stdio://"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            bufsize=1,
        )
    except OSError:
        return 1

    try:
        assert process.stdin is not None
        assert process.stdout is not None

        def send(message: dict) -> None:
            process.stdin.write(json.dumps(message) + "\n")
            process.stdin.flush()

        # Complete the handshake before asking for rate limits.  Sending both
        # requests at once is racy with some Codex CLI versions.
        send(
            {
                "id": 1,
                "method": "initialize",
                "params": {
                    "clientInfo": {
                        "name": "quickshell-codex-usage",
                        "version": "1.0.0",
                    }
                },
            }
        )

        selector = selectors.DefaultSelector()
        selector.register(process.stdout, selectors.EVENT_READ)
        deadline = time.monotonic() + 30
        initialized = False
        requested = False

        while time.monotonic() < deadline:
            if not selector.select(timeout=1):
                if process.poll() is not None:
                    return 1
                continue

            line = process.stdout.readline()
            if not line:
                continue

            try:
                response = json.loads(line)
            except json.JSONDecodeError:
                continue

            if response.get("id") == 1:
                if "error" in response:
                    return 1
                send({"method": "initialized", "params": {}})
                send({"id": 2, "method": "account/rateLimits/read", "params": {}})
                initialized = True
                requested = True
                continue

            if initialized and requested and response.get("id") == 2:
                if "error" in response:
                    return 1

                result = response.get("result", {})
                limits = result.get("rateLimits")
                if not limits:
                    limits = result.get("rateLimitsByLimitId", {}).get("codex")
                if not limits:
                    return 1

                weekly_used = -1
                for window in (limits.get("primary"), limits.get("secondary")):
                    if not window or "usedPercent" not in window:
                        continue

                    duration = window.get("windowDurationMins", 0)
                    if duration >= 10080:
                        weekly_used = max(0, min(100, round(float(window["usedPercent"]))))
                        break

                if weekly_used < 0:
                    return 1

                print(weekly_used)
                return 0

        return 1
    finally:
        process.terminate()
        try:
            process.wait(timeout=2)
        except subprocess.TimeoutExpired:
            process.kill()
            process.wait()


if __name__ == "__main__":
    sys.exit(main())
