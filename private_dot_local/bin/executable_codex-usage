#!/usr/bin/env python3
"""Print Codex subscription usage as: <5h used percent> <weekly used percent>."""

import json
import selectors
import shutil
import subprocess
import sys
import time


def main() -> int:
    codex = shutil.which("codex")
    if codex is None:
        return 1

    process = subprocess.Popen(
        [codex, "app-server", "--listen", "stdio://"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        bufsize=1,
    )

    try:
        assert process.stdin is not None
        assert process.stdout is not None

        requests = (
            {
                "id": 1,
                "method": "initialize",
                "params": {
                    "clientInfo": {
                        "name": "quickshell-codex-usage",
                        "version": "1.0.0",
                    }
                },
            },
            {"id": 2, "method": "account/rateLimits/read", "params": {}},
        )
        for request in requests:
            process.stdin.write(json.dumps(request) + "\n")
        process.stdin.flush()

        selector = selectors.DefaultSelector()
        selector.register(process.stdout, selectors.EVENT_READ)
        deadline = time.monotonic() + 30

        while time.monotonic() < deadline:
            if not selector.select(timeout=1):
                if process.poll() is not None:
                    return 1
                continue

            line = process.stdout.readline()
            if not line:
                continue

            try:
                response = json.loads(line)
            except json.JSONDecodeError:
                continue

            if response.get("id") != 2 or "error" in response:
                continue

            result = response.get("result", {})
            limits = result.get("rateLimits")
            if not limits:
                limits = result.get("rateLimitsByLimitId", {}).get("codex")
            if not limits:
                return 1

            session_used = -1
            weekly_used = -1
            for window in (limits.get("primary"), limits.get("secondary")):
                if not window or "usedPercent" not in window:
                    continue

                duration = window.get("windowDurationMins", 0)
                if duration <= 300:
                    session_used = round(window["usedPercent"])
                elif duration >= 10080:
                    weekly_used = round(window["usedPercent"])

            if session_used < 0 and weekly_used < 0:
                return 1

            print(f"{session_used} {weekly_used}")
            return 0

        return 1
    finally:
        process.terminate()
        try:
            process.wait(timeout=2)
        except subprocess.TimeoutExpired:
            process.kill()
            process.wait()


if __name__ == "__main__":
    sys.exit(main())
