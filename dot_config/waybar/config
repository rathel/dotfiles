{
  "layer": "top",
  "position": "top",
  "spacing": 10,
  "modules-center": ["custom/clock"],
  "modules-right": ["battery", "tray"],
  "modules-left": ["network"],

  "custom/clock": {
    "exec": "date '+%m/%d %H:%M'",
    "interval": 60
  },

  "tray": {
  	"icon-size": 18,
	"spacing": 10
  },

  "battery": {
      "bat": "BAT0",
      "interval": 60,
    },

  "network": {
    "format": "{bandwidthUpBytes}/{bandwidthDownBytes}",
  }
}
