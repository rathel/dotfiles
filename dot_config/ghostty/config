# ~/.config/ghostty/config

# Font
font-family = "IosevkaTerm Nerd Font"
font-size = 12

# UI / behavior
background-opacity = 1.0
window-padding-x = 10
window-padding-y = 10
# Ghostty measures scrollback in bytes; 10 MB comfortably covers 10,000 lines.
scrollback-limit = 10000000
copy-on-select = clipboard
confirm-close-surface = always
bell-features = no-system,no-audio,attention,title,no-border

# Cursor
cursor-style = block
cursor-style-blink = false

# Handy keybinds
keybind = ctrl+shift+enter=new_split:auto
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+bracket_right=next_tab
keybind = ctrl+shift+bracket_left=previous_tab

# Keep the window title blank.
title = " "

# Catppuccin Mocha Verdant
theme = catppuccin-mocha.conf
